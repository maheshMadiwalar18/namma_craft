# MongoDB Atlas Connection String
# Get yours from: https://cloud.mongodb.com → Connect → Drivers → Copy connection string
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/nammacraft?retryWrites=true&w=majority

# Server Port
PORT=5000

# Gemini API Key (optional)
GEMINI_API_KEY=your_gemini_api_key_here
